{
  "expo": {
    "name": "TalkTech",
    "slug": "talktech",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#20539D"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#20539D"
      },
      "package": "com.talktech.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite anexar fotos de equipamentos aos chamados.",
          "cameraPermission": "Permite fotografar equipamentos para os chamados."
        }
      ]
    ]
  }
}